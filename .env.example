# ProofHold environment configuration
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# All vars must be prefixed with VITE_ to be exposed to the client bundle.

VITE_NIMIQ_NETWORK=main

# Public custody address that holds buyer funds during a deal (from your hot wallet).
VITE_PROOFHOLD_CUSTODY_NIM_ADDR=NQ00 0000 0000 0000 0000 0000 0000 0000 0000

VITE_USDT_CHAIN_ID=137
VITE_USDT_CONTRACT_ADDR=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
VITE_USDT_DECIMALS=6
VITE_PROOFHOLD_CUSTODY_EVM_ADDR=0x0000000000000000000000000000000000000000

# Supabase project — anon (public) key only, never service_role key here
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─────────────────────────────────────────────────────────────────────────────
# Supabase Edge Function secrets (NOT VITE_ / not in the client bundle).
# Set via:  supabase secrets set KEY=value
#
# watcher + verify-payment (on-chain payment confirmation):
#   NIM_RPC=https://rpc.nimiqwatch.com
#   NIM_CUSTODY_ADDR=NQ.. (public custody address)
#   EVM_RPC=https://polygon-rpc.com
#   EVM_CUSTODY_ADDR=0x.. (public custody address)
#   USDT_CONTRACT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
#   USDT_DECIMALS=6
#
# payout (referral/fee marketplace settlement):
#   MARKETPLACE_FEE_BPS=100   # 1% (default if unset)
#
# notify + telegram-webhook (Telegram notifications):
#   TELEGRAM_BOT_TOKEN=123456:ABC...   (from BotFather)
#   TELEGRAM_WEBHOOK_SECRET=<random>   (echoed by Telegram in setWebhook)
#   Also set the bot handle in src/lib/host.ts (TELEGRAM_BOT) and register the
#   webhook once:  curl "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#     -d url=https://<ref>.supabase.co/functions/v1/telegram-webhook \
#     -d secret_token=<TELEGRAM_WEBHOOK_SECRET>
#
# bug-report (beta bug report emails):
#   RESEND_API_KEY=re_...                    (Resend API key)
#   BUG_REPORT_TO_EMAIL=official@xcrowhub.com
#   BUG_REPORT_FROM_EMAIL="XcrowHub Bug Reports <bugs@xcrowhub.com>"
#
# Cron → function auth (this project enforces the new API-key system, whose Edge
# gateway rejects legacy service-role JWTs). The pg_cron sweeps run with
# verify_jwt = false and send a shared CRON_SECRET, validated inside each handler.
#   1. Pick a strong random value, e.g.  openssl rand -hex 32
#   2. supabase secrets set CRON_SECRET=<value>     (shared by all functions)
#   3. Store the SAME value in Vault so the crons can read it:
#        select vault.update_secret(
#          (select id from vault.secrets where name = 'service_role_key' limit 1),
#          '<value>', 'service_role_key');
#      (app_service_key() reads this Vault entry; despite the legacy name it now
#       holds the CRON_SECRET, not a JWT.)
# ─────────────────────────────────────────────────────────────────────────────
